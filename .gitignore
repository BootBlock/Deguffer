# Rider / VS Code
.idea/
*.sln.iml

# .vscode stays ignored by default — it collects machine-local and credential-bearing files
# (mcp.json in particular). Share only the shape of the build, never the environment around it.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json

# Build and publish output for Deguffer.App. The leading "!" is escaped — unescaped it would
# read as a negation pattern and un-ignore whatever came before it.
\!Distribution/

