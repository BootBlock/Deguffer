{
    // F5 launches the WinUI 3 shell. The app is unpackaged (§6.3), so it debugs as an ordinary
    // self-contained executable — no MSIX deployment or loopback exemption step.
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Deguffer (x64)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build app (x64)",
            // Launch out of !Distribution, not bin/: the App project points OutputPath at the
            // flat !Distribution folder and suppresses the framework and RID subfolders, so it
            // never writes under bin/ at all. A stale bin/ path does not fail the launch — it
            // silently starts whatever exe was left there before the layout changed, so every
            // rebuild appears to have no effect.
            "program": "${workspaceFolder}/!Distribution/Deguffer.App.exe",
            "cwd": "${workspaceFolder}/!Distribution",
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Deguffer (x64, no build)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/!Distribution/Deguffer.App.exe",
            "cwd": "${workspaceFolder}/!Distribution",
            "console": "internalConsole",
            "stopAtEntry": false
        }
    ]
}
