<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Deguffer.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Deguffer.App"
    xmlns:converters="using:Deguffer.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:TierChipStyleConverter x:Key="TierChipStyle" />

            <!--
                §7's "colour by tier". These are Styles rather than loose brushes so the colours
                live in XAML as ThemeResource references: each element resolves them itself and
                re-resolves on a light/dark switch, which a brush handed over from C# cannot do.
                Shared by the finding rows and the tier reference on the About page, so the two
                cannot drift apart.
            -->
            <Style x:Key="TierChipBase" TargetType="ContentControl">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="9,2" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="VerticalAlignment" Value="Center" />

                <!-- ContentControl's default template is bare — it presents content and draws no
                     chrome at all, so Background, CornerRadius and Padding are ignored without
                     this. The template binds them instead of baking in colours, which is what
                     keeps the tier brushes in the per-tier styles below. -->
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContentControl">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TierChipRegenerableCache" TargetType="ContentControl" BasedOn="{StaticResource TierChipBase}">
                <Setter Property="Background" Value="{ThemeResource SystemFillColorSuccessBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource SystemFillColorSuccessBrush}" />
            </Style>

            <Style x:Key="TierChipRegenerableWithCost" TargetType="ContentControl" BasedOn="{StaticResource TierChipBase}">
                <Setter Property="Background" Value="{ThemeResource SystemFillColorCautionBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCautionBrush}" />
            </Style>

            <Style x:Key="TierChipUserData" TargetType="ContentControl" BasedOn="{StaticResource TierChipBase}">
                <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            </Style>

            <Style x:Key="TierChipDoNotTouch" TargetType="ContentControl" BasedOn="{StaticResource TierChipBase}">
                <Setter Property="Background" Value="{ThemeResource ControlAltFillColorSecondaryBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>

            <!--
                §6.5: colours come from theme brushes so they stay legible over unpredictable
                desktop content, in light and dark, and with the backdrop absent entirely.
            -->
            <Thickness x:Key="CardPadding">20</Thickness>
            <CornerRadius x:Key="CardCorner">8</CornerRadius>

            <!--
                One card per region, not one per row. Giving the free-space figure, the status
                line, every finding and the buttons an identical border made nothing more
                important than anything else, so the eye had no entry point. Weight now comes from
                type size and spacing; the card is only the surface holding a region together.
            -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource CardCorner}" />
                <Setter Property="Padding" Value="{StaticResource CardPadding}" />
            </Style>

            <Style x:Key="SectionHeading" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SecondaryText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <!-- The label above a figure: small, letter-spaced and quiet, so the number carries. -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="Figure" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="HeroFigure" TargetType="TextBlock" BasedOn="{StaticResource Figure}">
                <Setter Property="FontSize" Value="34" />
                <Setter Property="LineHeight" Value="40" />
            </Style>

            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- The hairline between findings, and between a page's regions. -->
            <Style x:Key="Divider" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>

            <!--
                The size bar on a finding row: slim, unlabelled, and never the only place a number
                appears. It exists so the relative weight of the rows is visible without reading
                every figure — §6.5 forbids encoding meaning where only the graphic carries it, so
                the size beside it always says the same thing in words. Hidden from assistive
                technology for that reason; the text is what gets announced.
            -->
            <Style x:Key="ShareBar" TargetType="ProgressBar">
                <Setter Property="Height" Value="3" />
                <Setter Property="Maximum" Value="100" />
                <Setter Property="Minimum" Value="0" />
                <Setter Property="IsIndeterminate" Value="False" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="IsTabStop" Value="False" />
                <Setter Property="AutomationProperties.AccessibilityView" Value="Raw" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
