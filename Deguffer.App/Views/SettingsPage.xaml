<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="Deguffer.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Deguffer.App.Views"
    Background="Transparent">

    <ScrollViewer Padding="28,8,28,28">
        <!-- Capped because these rows are a title and a sentence: run full-bleed on a wide window
             and the control drifts so far from the label that they stop reading as one row. -->
        <StackPanel Spacing="10" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource PageTitle}" Margin="0,0,0,6" />

            <InfoBar IsOpen="{x:Bind ViewModel.SaveFailed, Mode=OneWay}"
                     IsClosable="False"
                     Severity="Warning"
                     Title="Not saved"
                     Message="Your choice could not be written to disk, so it has not been applied. Check that %LOCALAPPDATA%\Deguffer is writable." />

            <TextBlock Text="Appearance" Style="{StaticResource SectionHeading}" FontSize="15" Margin="0,10,0,0" />

            <views:SettingsRow Glyph="&#xE771;"
                               Title="Theme"
                               Description="Light, dark, or whatever Windows is set to.">
                <views:SettingsRow.Control>
                    <ComboBox SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}"
                              MinWidth="150"
                              AutomationProperties.Name="Theme">
                        <ComboBoxItem Content="Use system setting" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </views:SettingsRow.Control>
            </views:SettingsRow>

            <!-- §6.5: the backdrop is decoration, so switching it off is a legitimate preference
                 and costs the user nothing. High contrast disables it regardless, which the
                 description says rather than leaving the toggle looking broken. -->
            <views:SettingsRow Glyph="&#xE790;"
                               Title="Translucent background"
                               Description="Blurs the desktop behind the window. Always off in high contrast, and Windows drops it on battery saver or over Remote Desktop.">
                <views:SettingsRow.Control>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.BackdropEnabled, Mode=TwoWay}"
                                  AutomationProperties.Name="Translucent background" />
                </views:SettingsRow.Control>
            </views:SettingsRow>

            <TextBlock Text="Safety" Style="{StaticResource SectionHeading}" FontSize="15" Margin="0,14,0,0" />

            <views:SettingsRow Glyph="&#xE730;"
                               Title="Confirm before cleaning"
                               Description="Lists what is about to be removed and asks once more. Deleting cannot be undone — these sizes are far past what the Recycle Bin will hold.">
                <views:SettingsRow.Control>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ConfirmBeforeCleaning, Mode=TwoWay}"
                                  AutomationProperties.Name="Confirm before cleaning" />
                </views:SettingsRow.Control>
            </views:SettingsRow>

            <!-- The only settings on this page that change what Deguffer will delete rather than
                 how it looks. Stated as scope rather than as a preference, because an empty list
                 is not a disabled feature — it is Deguffer having nowhere it is allowed to look. -->
            <TextBlock Text="Source folders" Style="{StaticResource SectionHeading}" FontSize="15" Margin="0,14,0,0" />

            <views:SettingsRow Glyph="&#xE8B7;"
                               Title="Where to look for build output"
                               Description="Deguffer looks for .NET intermediate build output (obj) inside these folders and nowhere else. Nothing outside them is ever offered, even when it is plainly build output.">
                <views:SettingsRow.Control>
                    <Button Content="Add folder…"
                            Click="OnAddSourceRoot"
                            AutomationProperties.Name="Add source folder" />
                </views:SettingsRow.Control>
            </views:SettingsRow>

            <TextBlock Text="No source folders added, so Deguffer will not look for build output anywhere."
                       Style="{StaticResource SecondaryText}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="4,0,0,0"
                       Visibility="{x:Bind ViewModel.HasNoSourceRoots, Mode=OneWay}" />

            <ItemsControl ItemsSource="{x:Bind ViewModel.SourceRoots, Mode=OneWay}" Margin="0,2,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Grid ColumnSpacing="10" Padding="12,8" Margin="0,0,0,4"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Bind}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTipService.ToolTip="{x:Bind}" />

                            <Button Grid.Column="1"
                                    Content="Remove"
                                    Tag="{x:Bind}"
                                    Click="OnRemoveSourceRoot"
                                    AutomationProperties.Name="Remove source folder" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource SecondaryText}"
                       FontSize="12"
                       Margin="4,10,0,0"
                       Text="Settings are stored in %LOCALAPPDATA%\Deguffer. Deleting that folder restores the defaults." />
        </StackPanel>
    </ScrollViewer>
</Page>
