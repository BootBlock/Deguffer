<?xml version="1.0" encoding="UTF-8" ?>
<UserControl
    x:Class="Deguffer.App.Views.SettingsRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}" Padding="18,14">
        <Grid ColumnSpacing="16" ColumnDefinitions="Auto,*,Auto">

            <FontIcon Grid.Column="0"
                      Glyph="{x:Bind Glyph, Mode=OneWay}"
                      FontSize="17"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                           Style="{StaticResource SecondaryText}"
                           FontSize="12" />
            </StackPanel>

            <ContentPresenter Grid.Column="2"
                              Content="{x:Bind Control, Mode=OneWay}"
                              VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
