<?xml version="1.0" encoding="UTF-8" ?>
<Window
    x:Class="Deguffer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <!--
            §6.5: the content extends into the title bar so the material runs the full height.
            This row is the drag region, and carries nothing but the app name — no information
            is placed where it would depend on the backdrop being present.
        -->
        <Border x:Name="TitleBar" Grid.Row="0" Height="40" Padding="16,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <!-- Decoded at the size it is drawn: the source is the 256px master, and without
                     this the full bitmap is decoded to fill an 18px slot. -->
                <Image Width="18" Height="18"
                       AutomationProperties.AccessibilityView="Raw">
                    <Image.Source>
                        <BitmapImage UriSource="ms-appx:///Assets/Deguffer-256.png"
                                     DecodePixelWidth="18" DecodePixelHeight="18" />
                    </Image.Source>
                </Image>
                <TextBlock
                    Text="Deguffer"
                    VerticalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Border>

        <!--
            A rail with permanent labels rather than a collapsible pane: there are three
            destinations and they will not grow, so nothing has to be opened to find out what is
            here. The pane toggle is hidden for the same reason — collapsing three items saves no
            meaningful width and costs the user the labels.
        -->
        <NavigationView x:Name="Navigation"
                        Grid.Row="1"
                        PaneDisplayMode="Left"
                        OpenPaneLength="184"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        IsPaneToggleButtonVisible="False"
                        Background="Transparent"
                        SelectionChanged="OnDestinationChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Storage" Tag="Clean" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Settings and About sit at the foot of the rail: they are where you go once, not
                 part of the task the window exists for. -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
