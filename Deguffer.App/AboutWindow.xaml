<?xml version="1.0" encoding="UTF-8" ?>
<Window
    x:Class="Deguffer.App.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <!-- §6.5: same arrangement as the main window — the drag region carries nothing that
             would be lost if the backdrop were absent. -->
        <Border x:Name="TitleBar" Grid.Row="0" Height="40" Padding="16,0">
            <TextBlock Text="About Deguffer"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Border>

        <StackPanel Grid.Row="1" Padding="32,8,32,32" Spacing="12" HorizontalAlignment="Center">
            <Image Source="ms-appx:///Assets/Deguffer-256.png"
                   Width="128" Height="128"
                   HorizontalAlignment="Center"
                   AutomationProperties.AccessibilityView="Raw" />

            <TextBlock Text="Deguffer"
                       HorizontalAlignment="Center"
                       FontSize="24" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <TextBlock x:Name="VersionText"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBlock Text="Finds and reclaims wasted disk space on a developer workstation."
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="320"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

            <HyperlinkButton Content="github.com/BootBlock/Deguffer"
                             NavigateUri="https://github.com/BootBlock/Deguffer"
                             HorizontalAlignment="Center" />

            <TextBlock Text="MIT licensed."
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Window>
